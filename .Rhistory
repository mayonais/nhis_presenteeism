library(dplyr)
library(broom)
library(haven)
library(MASS)
library(ggplot2)
library(hexbin)
data <- read_dta("nhis_00005.dta") %>%
rename_with(tolower) #convert to lowercase
#create dataset for modeling
data_model <- data %>%
mutate(
#outcome (valid 0–90; drop 96–99)
work_while_sick = ifelse(wrksickday <= 90, wrksickday, NA_real_),
#skip meds (1=no, 2=yes)
skip_meds = case_when(
yskipmedyr == 2 ~ 1,
yskipmedyr == 1 ~ 0,
TRUE ~ NA_real_
),
#headache severity (keep 2–4 only)
headache_severity = ifelse(painhead3m %in% 2:4,
painhead3m,
NA_real_),
#level of pain, last time had pain)
pain_level = ifelse(painfeelevl %in% 1:3,
painfeelevl,
NA_real_),
#sex (drop 7/8/9)
sex_factor = factor(ifelse(sex %in% c(1,2), sex, NA))
)
#create dataset for modeling
data_model <- data %>%
mutate(
#outcome (valid 0–90; drop 96–99)
work_while_sick = ifelse(wrksickday <= 90, wrksickday, NA_real_),
#skip meds (1=no, 2=yes)
skip_meds = case_when(
yskipmedyr == 2 ~ 1,
yskipmedyr == 1 ~ 0,
TRUE ~ NA_real_
),
#headache severity (keep 2–4 only)
headache_severity = ifelse(painhead3m %in% 2:4,
painhead3m,
NA_real_),
#level of pain, last time had pain)
pain_level = ifelse(painfeelevl %in% 1:3,
painfeelevl,
NA_real_),
#sex (drop 7/8/9)
sex_factor = factor(ifelse(sex %in% c(1,2), sex, NA))
)
#get residuals
res <- residuals(lm_fit)
#residuals vs fitted should be scattered, but are slightly trending downwards
#Q-Q is ok - roughly normal
#scale-location - slight heteroscedasticity (funnel)
#residuals vs leverage: vertical lines → many zeros influencing fit
par(mfrow = c(2,2))
plot(lm_fit)
#spikes at -1 and 0: many zero outcomes
hist(res, breaks = 20, main = "Residuals of LM", xlab = "Residual")
#many zeros and variance increases with mean (overdispersion)
hist(res, breaks = 20, main = "Residuals of LM", xlab = "Residual")
#many zeros and variance increases with mean (overdispersion)
hist(res, breaks = 20, main = "Residuals of LM", xlab = "Residual")
#compute Pearson residuals
pearson_resid <- residuals(pois_fit, type = "pearson")
#compute overdispersion ratio
dispersion_ratio <- sum(pearson_resid^2) / pois_fit$df.residual
dispersion_ratio #>1 = overdispension
---------------------------
#non binomial: explicitly models overdispersion
nb_fit <- glm.nb(work_while_sick ~ skip_meds + headache_severity + pain_level + age + sex_factor,
data = data_model)
---------------------------
#non binomial: explicitly models overdispersion
nb_fit <- glm.nb(work_while_sick ~ skip_meds + headache_severity + pain_level + age + sex_factor,
data = data_model)
summary(nb_fit)
---------------------------
#non binomial: explicitly models overdispersion
nb_fit <- glm.nb(work_while_sick ~ skip_meds + headache_severity +
pain_level + age + sex_factor + wldaysick,
data = data_model)
---------------------------
#non binomial: explicitly models overdispersion
nb_fit <- glm.nb(work_while_sick ~ skip_meds + headache_severity +
pain_level + age + sex_factor + wldaysick,
data = data_model)
summary(nb_fit)
#compares model quality
AIC(poisson_fit, nb_fit)
#compares model quality
AIC(pois_fit, nb_fit)
tidy(nb_fit)
