nb_null <- MASS::glm.nb(work_while_sick ~ 1, data = data_model)
# Compare them
anova(nb_null, nb_fit)
# Look at the range of the IRR
exp(confint(nb_fit))
#compares model quality
AIC(nb_fit)
# range of the IRR
exp(confint(nb_fit))
